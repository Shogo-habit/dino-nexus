---
import Layout from '../../layouts/Layout.astro';
import { GLOSSARY } from '../../data/glossary';
---

<Layout title="用語集 | Dino-Nexus" activeTab="glossary" description="恐竜の分類学や古生物学における専門用語を定義・解説する用語集。">
    <section class="page-header">
        <h1 class="page-title">用語集</h1>
        <p class="page-subtitle">古生物学データベース ＆ 用語定義</p>
    </section>

    <div class="glossary-list">
        {GLOSSARY.map(item => (
            <article class="glossary-item hud-panel" id={`term-${item.id}`} style="margin-bottom: 20px;">
                <h3 style="color: var(--primary-neon); margin-bottom: 10px;">
                    <dfn>{item.term}</dfn>
                </h3>
                <p style="font-size: 14px; line-height: 1.6; color: var(--text-main);">
                    {item.def}
                </p>
            </article>
        ))}
    </div>

    <div style="margin-top: 40px; text-align: right;">
        <div class="feedback-container" id="feedback-glossary" style="display: inline-flex; align-items: center; gap: 10px;">
            <span style="font-size: 11px; color: var(--text-dim); font-family: var(--font-mono);">
                期待したデータは得られましたか？
            </span>
            <button class="feedback-btn" id="feedback-yes" aria-label="はい">YES</button>
            <button class="feedback-btn" id="feedback-no" aria-label="いいえ">NO</button>
            <div class="feedback-msg" id="msg-glossary" style="font-size: 11px; color: var(--secondary-neon); font-family: var(--font-mono); opacity: 0; transition: opacity 0.3s ease; position: absolute; margin-top: 25px;"></div>
        </div>
    </div>

    <!-- Client-side feedback logic -->
    <script>
        function initGlossary() {
            const yesBtn = document.getElementById('feedback-yes');
            const noBtn = document.getElementById('feedback-no');
            const msgEl = document.getElementById('msg-glossary');

            if (yesBtn && noBtn && msgEl) {
                const showFeedbackMessage = (isPositive: boolean) => {
                    msgEl.innerText = isPositive 
                        ? "> フィードバック受理: 期待値との完全な同期を確認。" 
                        : "> フィードバック受理: 解析精度の再調整を要求中。";
                    msgEl.style.opacity = '1';
                    setTimeout(() => {
                        msgEl.style.opacity = '0';
                    }, 3000);
                };

                yesBtn.addEventListener('click', () => showFeedbackMessage(true));
                noBtn.addEventListener('click', () => showFeedbackMessage(false));
            }
        }

        document.addEventListener('astro:page-load', initGlossary);
    </script>
</Layout>
